{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dashboard-redirect",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-10",
  "routes": [
    { "pattern": "dashboard.ailedger.dev", "custom_domain": true }
  ],
  // Explicit (already the effective default with a custom_domain route): no
  // public *.workers.dev ingress. Pins both workers to custom-domain-only.
  "workers_dev": false
}
